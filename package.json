{
  "name": "pithub-test-root",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "client"
  ],
  "scripts": {
    "dev:client": "cd client && npm run dev",
    "dev:functions": "cd functions && npm run dev",
    "dev": "concurrently \"npm run dev:client\" \"firebase emulators:start\"",
    "build": "npm run build --workspace=client",
    "deploy": "firebase deploy"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
